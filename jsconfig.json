{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "three": ["./src/types/three.d.ts"],
      "@/*": ["./src/*"]
    },
    "allowJs": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/App.jsx",
    "src/main.jsx",
    "src/data/**/*.js",
    "src/pages/**/*.jsx",
    "src/components/portfolio/**/*.jsx",
    "src/lib/PageNotFound.jsx",
    "src/lib/utils.js",
    "src/hooks/**/*.jsx",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "src/vite-plugins", "src/components/ui", "src/api"]
}
